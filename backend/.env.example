# ============================================
# NexCRM Environment Variables
# Copy this file to .env and fill in all values
# ============================================

# --- Server ---
NODE_ENV=production
PORT=3001
API_URL=https://api.seudominio.com
FRONTEND_URL=https://seudominio.com
# Optional: allow multiple frontend domains in CORS (comma-separated)
# Example: FRONTEND_URLS=https://projeto.kreativ.ae,https://www.projeto.kreativ.ae
FRONTEND_URLS=

# --- MongoDB (REQUIRED) ---
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/nexcrm

# --- Redis (optional, improves performance) ---
REDIS_URL=redis://localhost:6379

# --- JWT Secrets (REQUIRED, min 32 chars, use: openssl rand -hex 64) ---
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# --- Email SMTP ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=NexCRM <noreply@seudominio.com>

# --- WhatsApp Business API ---
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_VERIFY_TOKEN=

# --- Meta (Facebook/Instagram) ---
META_APP_ID=
META_APP_SECRET=
META_PAGE_ACCESS_TOKEN=

# --- Telegram ---
TELEGRAM_BOT_TOKEN=

# --- OpenAI ---
OPENAI_API_KEY=

# --- Cloudinary (file uploads) ---
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- Stripe (payments) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- OAuth Providers ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=
APPLE_SERVICE_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=
